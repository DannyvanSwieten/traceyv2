{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Editor",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target tracey_c_api -j8 && (cmake --install ${workspaceFolder}/build || true) && cd ${workspaceFolder}/editor && pnpm build && cd src-tauri && cargo build",
            "group": "build",
            "problemMatcher": [
                "$gcc",
                "$rustc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Start Frontend Dev Server",
            "type": "shell",
            "command": "pnpm dev",
            "options": {
                "cwd": "${workspaceFolder}/editor"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*VITE.*$",
                    "endsPattern": "^.*Local:.*$"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "editor"
            }
        },
        {
            "label": "Build and Start Editor",
            "dependsOn": [
                "Build Editor",
                "Start Frontend Dev Server"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Build C++ Library",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target tracey_c_api -j8 && cmake --install ${workspaceFolder}/build",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Rust Editor",
            "type": "shell",
            "command": "cargo build",
            "options": {
                "cwd": "${workspaceFolder}/editor/src-tauri"
            },
            "group": "build",
            "problemMatcher": "$rustc"
        }
    ]
}
