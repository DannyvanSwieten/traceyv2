{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Tracey Editor",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target tracey_editor -j8",
            "group": "build",
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Start Frontend Dev Server",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/editor"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*VITE.*$",
                    "endsPattern": "^.*Local:.*$"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "editor"
            }
        },
        {
            "label": "Build Tracey Editor and Start Dev Server",
            "dependsOn": [
                "Build Tracey Editor",
                "Start Frontend Dev Server"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
