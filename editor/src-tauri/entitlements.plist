<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow reading and writing user-selected files -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Allow reading and writing downloads folder -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>

  <!-- Allow network access (for future use) -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Disable App Sandbox for development (enable proper entitlements for production) -->
  <key>com.apple.security.app-sandbox</key>
  <true/>

  <!-- Allow file system access for project directories -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
